# OpenAI
OPENAI_API_KEY=your_key_here

# Postgres (admin / migration role — owns the schema, may bypass RLS)
POSTGRES_USER=billing
POSTGRES_PASSWORD=billing
POSTGRES_DB=billing
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_CONNECTION_STRING=postgresql+asyncpg://billing:billing@postgres:5432/billing

# Application DB role (RLS-ENFORCED)
# The API and worker must connect to Postgres as a role that is SUBJECT TO RLS —
# NOT the table owner and NOT a BYPASSRLS/superuser role. Create this role in a
# migration, grant it only what it needs, and point the app at it here. The admin
# connection string above is for migrations only.
APP_DB_CONNECTION_STRING=postgresql+asyncpg://billing_app:billing_app@postgres:5432/billing

# App
PDF_MOUNT_PATH=/app/pdfs
LOG_LEVEL=INFO
ENVIRONMENT=development
WORKER_POLL_INTERVAL_SECONDS=5

# Auth (Better Auth, served from the Next.js app)
# Generate a strong random secret for real runs.
BETTER_AUTH_SECRET=change_me_to_a_long_random_string
BETTER_AUTH_URL=http://localhost:3000

# Frontend (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Connection string the Next.js app uses for auth tables / its own queries.
# Decide deliberately whether this is the admin role or an RLS-enforced role,
# and document the choice in docs/design.md.
DATABASE_URL=postgresql://billing:billing@postgres:5432/billing
